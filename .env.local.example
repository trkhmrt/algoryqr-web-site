# Yerel API / gateway ile test (prod URL’lerini ezer).
# Kullanım: kopyala → `.env.local`  (git’e girmez)
#
#   cp .env.local.example .env.local
#
# Sonra: `next dev` veya yerelde `next build && next start` ikisinde de bu değerler okunur.
#
# Komut alternatifi (.env.local olmadan prod build + yerel gateway):
#   npm run build:start:local
# Sadece sunucu, build yok (next dev + yerel gateway env):
#   npm run start:local

GATEWAY_BASE=http://localhost:8072
NEXT_PUBLIC_GATEWAY_BASE=http://localhost:8072

# Gateway’i atlayıp doğrudan AuthService (8099) — gateway kapalıyken
# AUTH_UPSTREAM=http://localhost:8099

# Prod’a dönmek için: `.env.local` dosyasını silin veya bu satırları yorumlayın.
# `next dev` içinde GATEWAY_BASE hiç set etmediyseniz kod zaten localhost:8072 kullanır.
