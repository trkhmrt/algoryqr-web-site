# ─── Geliştirme (.env.local kopyalayın; .gitignore’da) ───
# Auth: AUTH_UPSTREAM yoksa → GATEWAY_BASE + "/authservice"
# next dev: GATEWAY_BASE verilmezse varsayılan http://localhost:8072

# AUTH_UPSTREAM=http://localhost:8099
# GATEWAY_BASE=http://localhost:8072

# ─── Canlı ───
# Repoda `.env.production` tanımlı (next build). Platformda da şunları verin:
#   GATEWAY_BASE=https://gateway.algorycode.com
#   NEXT_PUBLIC_GATEWAY_BASE=https://gateway.algorycode.com
#   NEXT_PUBLIC_AUTH_BASE=https://auth.algorycode.com
#   AUTH_BASE=https://auth.algorycode.com
# AUTH_UPSTREAM prod’da genelde boş (gateway üzerinden gider).
