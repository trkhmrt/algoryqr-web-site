# Canlı ortam — `next build` sırasında yüklenir.
# Vercel / Docker / CI’da aynı anahtarları Environment Variables ile de tanımlayabilirsiniz (üzerine yazar).

# Auth proxy: getAuthUpstreamUrl() → GATEWAY_BASE + "/authservice"
# QR proxy: GATEWAY_BASE + "/qr/..."
GATEWAY_BASE=https://gateway.algorycode.com
NEXT_PUBLIC_GATEWAY_BASE=https://gateway.algorycode.com

# Public auth kökü (ileride istemci kullanımı için)
NEXT_PUBLIC_AUTH_BASE=https://auth.algorycode.com
AUTH_BASE=https://auth.algorycode.com

# Prod’da boş bırakın (gateway üzerinden gider). Sadece özel durumda gateway bypass:
# AUTH_UPSTREAM=https://...
